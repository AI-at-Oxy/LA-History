SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=1

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# Optional: required only for password-reset emails
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-app-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=LA History <your-app-email@example.com>

# Optional: production database (dev uses SQLite by default)
DATABASE_URL=postgresql://user:password@host:5432/dbname

RATELIMIT_STORAGE_URI=memory://
PASSWORD_RESET_EXPIRY_SECONDS=3600
